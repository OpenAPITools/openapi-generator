    call.receiveMultipart().forEachPart { part ->
        when (part.name) {
            {{#allParams}}
            {{#isFormParam}}
            "{{baseName}}" -> {
                {{#isFile}}
                if(part is PartData.FileItem) {
                    builder.onReceive{{#lambda.titlecase}}{{paramName}}{{/lambda.titlecase}}(part)
                }
                {{/isFile}}
                {{^isFile}}
                if(part is PartData.FormItem) {
                    builder.{{paramName}}(part.value{{>libraries/ktor/_extract_param_value}})
                }
                {{/isFile}}
            }
            {{/isFormParam}}
            {{/allParams}}
        }
        part.dispose()
    }
    builder.build()
}
