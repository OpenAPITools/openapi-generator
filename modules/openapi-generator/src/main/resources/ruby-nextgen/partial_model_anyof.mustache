    # anyOf wrapper. Returns the first candidate that validates.
    module {{classname}}
      CANDIDATES = [
{{#anyOf}}
        '{{{.}}}',
{{/anyOf}}
      ].freeze

      def self.build(data)
        CANDIDATES.each do |type_name|
          next if type_name == 'AnyType'

          result = {{moduleName}}::Polymorphism.cast(type_name, data)
          return result unless result.nil?
        end
        return data if CANDIDATES.include?('AnyType')

        # No candidate matched: surface the payload drift instead of returning a silent
        # nil that would only fail later as a downstream NoMethodError.
        raise ArgumentError, "anyOf for #{name}: no candidate matched #{CANDIDATES.inspect}"
      end
    end
