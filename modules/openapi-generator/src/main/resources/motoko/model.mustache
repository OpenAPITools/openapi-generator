                    {{#vendorExtensions.x-string-or-array-element-is-model}}{{vendorExtensions.x-string-or-array-element-type}}.toCandidValue{{/vendorExtensions.x-string-or-array-element-is-model}}{{^vendorExtensions.x-string-or-array-element-is-model}}func(s : {{vendorExtensions.x-string-or-array-element-type}}) : Candid.Candid = #Text(s){{/vendorExtensions.x-string-or-array-element-is-model}}
                ));
