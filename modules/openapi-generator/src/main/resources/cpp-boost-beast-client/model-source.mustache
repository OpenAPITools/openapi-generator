std::string {{classname}}::toJsonString(bool prettyJson /* = false */) const
{
    const auto value = toJsonValue();
    if (!prettyJson) {
        return boost::json::serialize(value);
    }

    std::ostringstream output;
    std::string indent;
    writePrettyJson(output, value, indent);
    return output.str();
}

