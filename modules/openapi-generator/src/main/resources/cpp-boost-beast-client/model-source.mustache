// C++17-compatible trait to detect types with toJsonValue() const member.
template <typename T, typename = void>
struct HasToJsonValue : std::false_type {};

template <typename T>
struct HasToJsonValue<T, std::void_t<decltype(std::declval<const T&>().toJsonValue())>> : std::true_type {};

// Recursively converts a variant branch to boost::json::value.
// Primary template: use value_from for primitives and standard types.
template <typename T, typename = void>
struct VariantJsonHelper {
    static boost::json::value toJsonValue(const T& v) {
        return boost::json::value_from(v);
    }
};

// Specialization for types that expose toJsonValue() (e.g. model classes).
template <typename T>
struct VariantJsonHelper<T, std::enable_if_t<HasToJsonValue<T>::value>> {
    static boost::json::value toJsonValue(const T& v) {
        return v.toJsonValue();
    }
};

// Specialization for std::vector — iterate and convert each element.
template <typename Element>
struct VariantJsonHelper<std::vector<Element>> {
    static boost::json::value toJsonValue(const std::vector<Element>& v) {
        boost::json::array result;
        result.reserve(v.size());
        for (const auto& elem : v) {
            result.emplace_back(VariantJsonHelper<Element>::toJsonValue(elem));
        }
        return result;
    }
};

// Specialization for std::map — iterate and convert each mapped value.
template <typename MappedValue>
struct VariantJsonHelper<std::map<std::string, MappedValue>> {
    static boost::json::value toJsonValue(const std::map<std::string, MappedValue>& m) {
        boost::json::object result;
        for (const auto& entry : m) {
            result[entry.first] = VariantJsonHelper<MappedValue>::toJsonValue(entry.second);
        }
        return result;
    }
};

// Specialization for std::variant — recursively visit nested variants.
template <typename... Ts>
struct VariantJsonHelper<std::variant<Ts...>> {
    static boost::json::value toJsonValue(const std::variant<Ts...>& v) {
        return std::visit([](auto const& alt) -> boost::json::value {
            return VariantJsonHelper<std::decay_t<decltype(alt)>>::toJsonValue(alt);
        }, v);
    }
};
}

